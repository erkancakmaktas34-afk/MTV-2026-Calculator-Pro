// function goBack() removed - logic moved to handleBack



function renderResultView(container) {
    const res = calculateTaxFromState();
    const details = formData.displayDetails;

    const map = {
        'otomobil': 'Otomobil', 'motosiklet': 'Motosiklet', 'kamyonet': 'Kamyonet', 'minibus': 'Minibüs', 'panelvan': 'Panel Van',
        'otobus': 'Otobüs', 'ucak': 'Uçak', 'helikopter': 'Helikopter',
        'elektrikli_otomobil': 'Elektrikli Otomobil', 'elektrikli_motosiklet': 'Elektrikli Motosiklet',
        'elektrikli_minibus': 'Elektrikli Minibüs', 'elektrikli_panelvan': 'Elektrikli Panelvan',
        'elektrikli_otobus': 'Elektrikli Otobüs', 'elektrikli_kamyonet': 'Elektrikli Kamyon'
    };

    let detailRows = '';
    const addRow = (label, value) => {
        if (value) {
            detailRows += `<div class="flex justify-between border-b border-white/5 py-0.25 last:border-0"><span class="text-gray-400">${label}:</span><span class="font-medium text-white">${value}</span></div>`;
        }
    };

    addRow('Araç Türü', map[formData.vehicleType] || formData.vehicleType.replace(/_/g, ' ').toUpperCase());

    if (formData.vehicleModelYear) {
        const calculatedAge = 2026 - parseInt(formData.vehicleModelYear) + 1;
        addRow('Model Yılı', `${formData.vehicleModelYear} (${calculatedAge} Yaşında)`);
    } else {
        addRow('Araç Yaşı', details.ageLabel || formData.vehicleAge);
    }

    if (formData.engineSize && (formData.vehicleType === 'otomobil')) { addRow('Motor Hacmi', details.engineLabel); }
    if (formData.motorPower && formData.vehicleType.startsWith('elektrikli_')) { addRow('Motor Gücü', details.powerLabel); }
    if (formData.motoEngine && formData.vehicleType.includes('motosiklet')) { addRow('Motor Hacmi', details.motoLabel); }
    if (formData.vehicleWeight) {
        const lbl = formData.vehicleType.includes('ucak') || formData.vehicleType.includes('helikopter') ? 'Azami Kalkış Ağırlığı' : 'Azami Toplam Ağırlık';
        addRow(lbl, details.weightLabel);
    }
    if (formData.panelvanEngine && formData.vehicleType.includes('panelvan')) { addRow('Motor Tipi', details.panelvanLabel); }
    if (formData.vehicleSeat && (formData.vehicleType.includes('minibus') || formData.vehicleType.includes('otobus'))) { addRow('Kapasite', details.seatLabel); }

    if (formData.displayDetails.matrahLabel) { addRow('Matrah (Vergisiz Değer)', details.matrahLabel); }

    container.innerHTML = `
    <div class="animate-zoom-in flex flex-col px-0">
        <h2 class="text-xl font-black text-center mb-1 leading-tight flex-shrink-0">MTV Hesaplandı</h2>
        
        <div class="flex-1 overflow-y-auto custom-scrollbar flex flex-col gap-1.5 min-h-0 relative z-0">
            <div class="bg-white/5 rounded-2xl pt-2.5 px-2.5 pb-1.5 border border-white/10 overflow-hidden relative flex-grow flex flex-col justify-center min-h-[140px]">
                 <div class="text-center mb-0.5 z-10 relative">
                    <p class="text-[9px] text-gray-400 mb-0 uppercase tracking-widest">Yıllık Toplam</p>
                    <div id="total-tax-anim" class="text-4xl font-black text-primary">0 TL</div>
                 </div>
                 <div class="grid grid-cols-2 gap-2 mt-0.5 z-10 relative">
                    <div class="bg-white/5 p-2 rounded-xl border border-white/5 text-center">
                        <p class="text-[9px] text-gray-400 uppercase tracking-tighter mb-0">Ocak</p>
                        <p id="inst1-anim" class="text-xl font-black text-white">0 TL</p>
                    </div>
                    <div class="bg-white/5 p-2 rounded-xl border border-white/5 text-center">
                        <p class="text-[9px] text-gray-400 uppercase tracking-tighter mb-0">Temmuz</p>
                        <p id="inst2-anim" class="text-xl font-black text-white">0 TL</p>
                    </div>
                 </div>
                 <p class="text-[11px] text-gray-500 text-center mt-1.5 opacity-80">Taksitler kuruş hassasiyeti ile hesaplanmıştır.</p>
            </div>

            <div class="bg-white/3 rounded-2xl p-2.5 text-[11px] space-y-0.5 border border-white/5 flex-grow flex flex-col justify-center">
                 ${detailRows}
            </div>
        </div>

        ${!isPremium ? `
        <div class="flex-shrink-0 mt-3">
            <button onclick="removeAds()" class="remove-ads-btn group relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                <i data-lucide="zap" class="w-4 h-4 fill-yellow-500 animate-bounce"></i> 
                REKLAMLARI KALDIR
            </button>
        </div>
        ` : ''}

        <div class="relative flex-shrink-0 mt-2 z-50">
            <button onclick="shareResult()" class="share-btn">
                <i data-lucide="share-2" class="w-4 h-4"></i> PAYLAŞ
            </button>
        </div>

        <div class="grid grid-cols-2 gap-3 mt-4 mb-1 flex-shrink-0 z-40">
            <button onclick="handleBackToDetails()" class="back-to-details-btn">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> GERİ
            </button>
            <button onclick="handleFullReset()" class="full-reset-btn">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i> BAŞA DÖN
            </button>
        </div>
    </div>
    `;

    // Start Animations
    const rawTotal = parseInt(res.total.replace(/[^0-9]/g, ''));
    const rawInst = rawTotal / 2;

    animateValue("total-tax-anim", 0, rawTotal, 1000, 0);
    animateValue("inst1-anim", 0, rawInst, 1000, 2);
    animateValue("inst2-anim", 0, rawInst, 1000, 2);
}

function animateValue(id, start, end, duration, decimals = 0) {
    const obj = document.getElementById(id);
    if (!obj) return;

    let startTimestamp = null;
    const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const current = progress * (end - start) + start;

        // Hide kuruş if it's a whole number at the end, or follow requested decimals
        const hasDecimals = current % 1 !== 0;
        const minFrac = hasDecimals ? 2 : 0;

        obj.innerHTML = new Intl.NumberFormat('tr-TR', {
            style: 'currency',
            currency: 'TRY',
            minimumFractionDigits: minFrac,
            maximumFractionDigits: 2
        }).format(current);
        if (progress < 1) {
            window.requestAnimationFrame(step);
        }
    };
    window.requestAnimationFrame(step);
}

async function shareResult() {
    const res = calculateTaxFromState();
    const details = formData.displayDetails;

    const map = {
        'otomobil': 'Otomobil', 'motosiklet': 'Motosiklet', 'kamyonet': 'Kamyonet', 'minibus': 'Minibüs', 'panelvan': 'Panel Van',
        'otobus': 'Otobüs', 'ucak': 'Uçak', 'helikopter': 'Helikopter',
        'elektrikli_otomobil': 'Elektrikli Otomobil', 'elektrikli_motosiklet': 'Elektrikli Motosiklet',
        'elektrikli_minibus': 'Elektrikli Minibüs', 'elektrikli_panelvan': 'Elektrikli Panelvan',
        'elektrikli_otobus': 'Elektrikli Otobüs', 'elektrikli_kamyonet': 'Elektrikli Kamyon'
    };

    let text = `2026 MTV Hesaplama Sonucu\n`;
    text += `--------------------------\n`;
    text += `Araç Türü: ${map[formData.vehicleType] || formData.vehicleType}\n`;

    if (formData.vehicleModelYear) {
        const calculatedAge = 2026 - parseInt(formData.vehicleModelYear) + 1;
        text += `Model Yılı: ${formData.vehicleModelYear} (${calculatedAge} Yaşında)\n`;
    } else if (formData.vehicleAge) {
        text += `Araç Yaşı: ${details.ageLabel || formData.vehicleAge}\n`;
    }

    if (formData.engineSize && formData.vehicleType === 'otomobil') { text += `Motor Hacmi: ${details.engineLabel}\n`; }
    if (formData.motorPower && formData.vehicleType.startsWith('elektrikli_')) { text += `Motor Gücü: ${details.powerLabel}\n`; }
    if (formData.motoEngine && formData.vehicleType.includes('motosiklet')) { text += `Motor Seçeneği: ${details.motoLabel}\n`; }
    if (formData.vehicleWeight) {
        const lbl = formData.vehicleType.includes('ucak') || formData.vehicleType.includes('helikopter') ? 'Kalkış Ağırlığı' : 'Toplam Ağırlık';
        text += `${lbl}: ${details.weightLabel}\n`;
    }
    if (formData.panelvanEngine && formData.vehicleType.includes('panelvan')) { text += `Motor Tipi: ${details.panelvanLabel}\n`; }
    if (formData.vehicleSeat && (formData.vehicleType.includes('minibus') || formData.vehicleType.includes('otobus'))) { text += `Kapasite: ${details.seatLabel}\n`; }
    if (details.matrahLabel) { text += `Matrah: ${details.matrahLabel}\n`; }

    text += `--------------------------\n`;
    text += `Yıllık Toplam: ${res.total}\n`;
    text += `Taksitler: ${res.inst1} x 2\n\n`;
    text += `MTV 2026 uygulaması ile hesaplanmıştır.`;

    const share = window.Capacitor?.Plugins?.Share;
    if (share) {
        share.share({
            title: 'MTV 2026 Sonucu',
            text: text,
            dialogTitle: 'Sonucu Paylaş'
        }).catch(e => { });
    } else {
        window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
    }
}


// --- GENERATORS ---

function getHelpersHTML() {
    const type = formData.vehicleType;
    let html = '';
    if (type.startsWith('elektrikli_') || (type === 'otomobil' && formData.registrationDate === 'after2018')) {
        html += `<button onclick="showMatrahInfo()" class="text-xs text-text-dim hover:text-accent-primary flex items-center gap-1 transition-colors"><i data-lucide="help-circle" class="w-3 h-3"></i> Matrah nedir?</button>`;
    }
    if (type.includes('kamyonet')) {
        html += `<button onclick="showKamyonetInfo()" class="text-xs text-warningAmber hover:text-white flex items-center gap-1 transition-colors bg-warningAmber/10 px-2 py-1 rounded-lg border border-warningAmber/20"><i data-lucide="alert-triangle" class="w-3 h-3"></i> Ruhsat Uyarısı</button>`;
    }
    return html;
}

function getElectricSwitcherHTML() {
    return `
    <div class="mb-4 p-3 bg-white/5 rounded-2xl border border-white/10">
        <label class="block text-sm font-medium text-electricBlue mb-2">Elektrikli Araç Türü</label>
        <div class="grid grid-cols-3 gap-2">
            ${createTypeBtn('Otomobil', 'elektrikli_otomobil', 'car')}
            ${createTypeBtn('Motosiklet', 'elektrikli_motosiklet', 'bike')}
            ${createTypeBtn('Minibüs', 'elektrikli_minibus', 'bus')}
            ${createTypeBtn('Panelvan', 'elektrikli_panelvan', 'box')}
            ${createTypeBtn('Otobüs', 'elektrikli_otobus', 'bus-front')}
            ${createTypeBtn('Kamyon', 'elektrikli_kamyonet', 'truck')}
        </div>
    </div>`;
}

function createTypeBtn(label, value, icon) {
    const isSel = formData.vehicleType === value;
    const activeClass = isSel ? 'bg-electricBlue text-deepNavy border-electricBlue' : 'bg-transparent text-gray-400 border-gray-700 hover:border-gray-500';
    return `<button onclick="switchSubType('${value}')" class="${activeClass} border rounded-xl p-2 flex flex-col items-center gap-1 transition-all text-xs font-semibold"><i data-lucide="${icon}" class="w-4 h-4"></i>${label}</button>`;
}

function getBodyInputsHTML() {
    const type = formData.vehicleType;

    // Strict Routing
    if (type === 'otomobil' || type === 'elektrikli_otomobil') {
        return generateAutoInputs(type);
    }

    if (type === 'motosiklet' || type === 'elektrikli_motosiklet') {
        return generateMotoInputs();
    }

    // Fallback for all other types (Kamyonet, Minibus, Otobus, Panelvan, etc.)
    // Includes both electric and ICE versions
    return generateOtherInputs(type);
}



function generateAutoInputs(type) {
    let dateHTML = '';
    if (!type.startsWith('elektrikli_')) {
        dateHTML = `
        <div class="mb-2">
            <label class="block text-sm font-medium text-gray-300 mb-1">Tescil Tarihi</label>
            <div class="grid grid-cols-2 gap-2">
                <label class="cursor-pointer group relative">
                    <input type="radio" name="rdate" value="after2018" class="peer sr-only" ${formData.registrationDate === 'after2018' ? 'checked' : ''} onchange="handleDateSwitch('after2018')">
                    <div class="p-2 rounded-xl border border-white/10 bg-white/5 peer-checked:border-electricBlue peer-checked:bg-electricBlue/10 transition-all hover:border-white/30 text-center h-full flex flex-col justify-center items-center gap-1">
                        <span class="text-[14px] font-bold text-white">01.01.2018</span>
                        <span class="text-[12px] text-gray-400 peer-checked:text-electricBlue">ve Sonrası</span>
                    </div>
                </label>
                <label class="cursor-pointer group relative">
                    <input type="radio" name="rdate" value="before2018" class="peer sr-only" ${formData.registrationDate === 'before2018' ? 'checked' : ''} onchange="handleDateSwitch('before2018')">
                    <div class="p-2.5 rounded-xl border border-white/10 bg-white/5 peer-checked:border-electricBlue peer-checked:bg-electricBlue/10 transition-all hover:border-white/30 text-center h-full flex flex-col justify-center items-center gap-1">
                        <span class="text-[14px] font-bold text-white">31.12.2017</span>
                        <span class="text-[12px] text-gray-400 peer-checked:text-electricBlue">ve Öncesi</span>
                    </div>
                </label>
            </div>
        </div>`;
    }

    let engineHTML = '';
    if (type === 'otomobil') {
        engineHTML = `<div><label class="block text-sm font-medium text-gray-300 mb-1">Motor Silindir Hacmi</label>
            <div class="custom-select-trigger" onclick="openEnginePicker()">
                <span id="trigger-engine">${formData.displayDetails.engineLabel || 'Seçiniz'}</span>
                <div class="arrow"></div>
            </div>
        </div>`;
    } else if (type === 'elektrikli_otomobil') {
        engineHTML = `<div><label class="block text-sm font-medium text-gray-300 mb-1">Motor Gücü (kW)</label>
        <div class="custom-select-trigger" onclick="openPowerPicker()">
            <span id="trigger-power">${formData.displayDetails.powerLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }

    const infoText = type.startsWith('elektrikli')
        ? "Matrah tüm yaşlar için geçerlidir. Doğru limitler için lütfen Model Yılı seçiniz."
        : "Matrah 1-6 yaş arası için geçerlidir. Doğru limitler için lütfen Model Yılı seçiniz.";

    const ageHtml = getYearAgeHTML(type);
    const isPost2018Auto = (type === 'otomobil' && formData.registrationDate === 'after2018');
    const isElectricAuto = (type === 'elektrikli_otomobil');
    const initialDisplay = (isPost2018Auto || isElectricAuto) ? 'block' : 'none';

    const matrahHtml = `<div id="matrahContainer" style="display:${initialDisplay}">
    <label class="block text-sm font-medium text-gray-300 mb-1">Araç Vergisiz Değeri (Matrah)</label>
    <div class="custom-select-trigger" onclick="openMatrahPicker()">
        <span id="trigger-matrah">${formData.displayDetails.matrahLabel || 'Seçiniz'}</span>
        <div class="arrow"></div>
    </div>
    <p class="text-[11px] text-warningAmber mt-1 leading-snug"><i data-lucide="info" class="w-3.5 h-3.5 inline-block mr-0.5"></i> ${infoText}</p>
    </div>`;

    return `<div class="space-y-2">${dateHTML}${engineHTML}${ageHtml}${matrahHtml}</div>`;
}

function generateMotoInputs() {
    const isElectric = formData.vehicleType === 'elektrikli_motosiklet';
    const label = isElectric ? 'Motor Gücü (kW)' : 'Motor Silindir Hacmi';

    let engineHTML = `<div><label class="block text-sm font-medium text-gray-300 mb-2">${label}</label>
    <div class="custom-select-trigger" onclick="openMotoPicker()">
        <span id="trigger-moto">${formData.displayDetails.motoLabel || 'Seçiniz'}</span>
        <div class="arrow"></div>
    </div></div>`;

    return `<div class="space-y-4">${engineHTML}${getYearAgeHTML(formData.vehicleType)}</div>`;
}

function generateOtherInputs(type) {
    let extra = '';
    if (type.includes('kamyonet')) {
        extra = `<div><label class="block text-sm font-medium text-gray-300 mb-2">Azami Toplam Ağırlık</label>
        <div class="custom-select-trigger" onclick="openWeightPicker()">
            <span id="trigger-weight">${formData.displayDetails.weightLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }
    else if (type.includes('minibus')) {
        extra = `<div><label class="block text-sm font-medium text-gray-300 mb-2">Koltuk Sayısı (Sürücü Dahil)</label>
        <div class="custom-select-trigger" onclick="openSeatPicker()">
            <span id="trigger-seat">${formData.displayDetails.seatLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }
    else if (type.includes('otobus')) {
        extra = `<div><label class="block text-sm font-medium text-gray-300 mb-2">Koltuk Sayısı (Sürücü Dahil)</label>
        <div class="custom-select-trigger" onclick="openSeatPicker()">
            <span id="trigger-seat">${formData.displayDetails.seatLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }
    else if (type.includes('panelvan')) {
        extra = `<div><label class="block text-sm font-medium text-gray-300 mb-2">Motor / Güç Tipi</label>
        <div class="custom-select-trigger" onclick="openPanelvanPicker()">
            <span id="trigger-panelvan">${formData.displayDetails.panelvanLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }
    else if (type === 'ucak' || type === 'helikopter') {
        extra = `<div><label class="block text-sm font-medium text-gray-300 mb-2">Azami Kalkış Ağırlığı</label>
        <div class="custom-select-trigger" onclick="openWeightPicker()">
            <span id="trigger-weight">${formData.displayDetails.weightLabel || 'Seçiniz'}</span>
            <div class="arrow"></div>
        </div></div>`;
    }

    return `<div class="space-y-4">${extra}${getYearAgeHTML(type)}</div>`;
}

function getYearAgeHTML(type) {
    const isElectric = type.startsWith('elektrikli');
    const isPost2018Auto = (type === 'otomobil' && formData.registrationDate === 'after2018');
    const isPre2018Auto = (type === 'otomobil' && formData.registrationDate === 'before2018');
    const isElectricAuto = (type === 'elektrikli_otomobil');
    const isElectricMoto = (type === 'elektrikli_motosiklet');

    let minYear = 1977;
    let maxYear = 2026;

    if (isElectricAuto) {
        minYear = 2019;
    } else if (isPost2018Auto) {
        minYear = 2018;
    } else if (isPre2018Auto) {
        maxYear = 2017;
    }

    const savedAge = formData.vehicleAge || '';

    let yearOptions = '<option value="" selected>Seçiniz</option>';
    for (let yr = maxYear; yr >= minYear; yr--) {
        yearOptions += `<option value="${yr}">${yr}</option>`;
    }

    if (maxYear >= 2011 && minYear <= 2011) {
        yearOptions += `<option value="2011_down">2011 ve Öncesi (16+ Yaş)</option>`;
    }

    let ageOptions = '<option value="">Seçiniz</option>';
    const isComm = ['minibus', 'otobus', 'kamyonet', 'panelvan', 'elektrikli_minibus', 'elektrikli_otobus', 'elektrikli_kamyonet', 'elektrikli_panelvan'].includes(type) || type.includes('kamyonet');
    const isAir = (type === 'ucak' || type === 'helikopter');

    const addOpt = (val, txt) => `<option value="${val}" ${isSelected(val, savedAge)}>${txt}</option>`;

    if (isAir) {
        ageOptions += addOpt('1-3', '1 - 3 Yaş');
        ageOptions += addOpt('4-5', '4 - 5 Yaş');
        ageOptions += addOpt('6-10', '6 - 10 Yaş');
        ageOptions += addOpt('11+', '11+ Yaş');
    } else if (isComm) {
        ageOptions += addOpt('1-6', '1 - 6 Yaş');
        ageOptions += addOpt('7-15', '7 - 15 Yaş');
        ageOptions += addOpt('16+', '16+ Yaş');
    } else if (type === 'motosiklet') {
        ageOptions += addOpt('1-3', '1 - 3 Yaş');
        ageOptions += addOpt('4-6', '4 - 6 Yaş');
        ageOptions += addOpt('7-11', '7 - 11 Yaş');
        ageOptions += addOpt('12-15', '12 - 15 Yaş');
        ageOptions += addOpt('16+', '16+ Yaş');
    } else {
        // Otomobil ve diğerleri (Motosiklet/Ticari hariç)
        if (isPost2018Auto) {
            // 2018 ve sonrası: Sadece genç yaşlar (Maks 2026-2018+1 = 9 yaş)
            ageOptions += addOpt('1-3', '1 - 3 Yaş');
            ageOptions += addOpt('4-6', '4 - 6 Yaş');
            ageOptions += addOpt('7-11', '7 - 11 Yaş');
        } else if (isPre2018Auto) {
            // 2017 ve öncesi: Sadece yaşlı yaşlar (Min 2026-2017+1 = 10 yaş)
            ageOptions += addOpt('7-11', '7 - 11 Yaş');
            ageOptions += addOpt('12-15', '12 - 15 Yaş');
            ageOptions += addOpt('16+', '16+ Yaş');
        } else {
            // Elektrikli otomobil veya diğer genel durumlar
            ageOptions += addOpt('1-3', '1 - 3 Yaş');
            ageOptions += addOpt('4-6', '4 - 6 Yaş');
            ageOptions += addOpt('7-11', '7 - 11 Yaş');
            ageOptions += addOpt('12-15', '12 - 15 Yaş');
            ageOptions += addOpt('16+', '16+ Yaş');
        }
    }

    // Profesyonel disabled state - hangisi seçiliyse diğeri pasif
    const yearDisabled = formData.vehicleAge && !formData.vehicleModelYear ? 'disabled-field' : '';
    const ageDisabled = formData.vehicleModelYear ? 'disabled-field' : ''; // Model yılı varsa pasif

    return `
    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Model Yılı</label>
            <div class="custom-select-trigger ${yearDisabled}" id="year-trigger" onclick="openCustomYearPicker()">
                <span id="trigger-year">${formData.vehicleModelYear || 'Seçiniz'}</span>
                <div class="arrow"></div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Araç Yaşı</label>
            <div class="custom-select-trigger ${ageDisabled}" id="age-trigger" onclick="openCustomAgePicker()">
                <span id="trigger-age">${formData.displayDetails.ageLabel || 'Seçiniz'}</span>
                <div class="arrow"></div>
            </div>
        </div>
    </div>`;
}

// --- CUSTOM PICKER CORE LOGIC ---
let currentPickerCallback = null;

function openCustomPicker(title, options, currentVal, callback) {
    const overlay = document.getElementById('picker-overlay');
    const sheet = document.getElementById('picker-sheet');
    const titleEl = document.getElementById('picker-title');
    const optionsEl = document.getElementById('picker-options');

    if (!overlay || !sheet || !titleEl || !optionsEl) return;

    titleEl.innerText = title;
    currentPickerCallback = callback;

    // Build options
    optionsEl.innerHTML = options.map(opt => {
        const isSelected = String(opt.value) === String(currentVal);
        return `
            <button class="picker-option ${isSelected ? 'selected' : ''}" 
                    onclick="handlePickerSelection('${opt.value}', '${opt.label.replace(/'/g, "\\'")}')">
                ${opt.label}
            </button>
        `;
    }).join('');

    overlay.classList.remove('hidden');
    // Force a tiny delay for CSS transition
    setTimeout(() => overlay.classList.add('active'), 10);
    document.body.style.overflow = 'hidden';
}

function handlePickerSelection(value, label) {
    if (currentPickerCallback) {
        currentPickerCallback(value, label);
    }
    closePicker();
}

function closePicker() {
    const overlay = document.getElementById('picker-overlay');
    if (overlay) {
        overlay.classList.remove('active');
        setTimeout(() => {
            overlay.classList.add('hidden');
            document.body.style.overflow = '';
        }, 300);
    }
}

// --- SPECIFIC PICKER HANDLERS ---

function openCustomYearPicker() {
    // Profesyonel: Araç yaşı seçiliyse temizle ve devam et
    if (formData.vehicleAge && !formData.vehicleModelYear) {
        formData.vehicleAge = '';
        formData.displayDetails.ageLabel = '';
    }

    const type = formData.vehicleType;
    const isPost2018Auto = (type === 'otomobil' && formData.registrationDate === 'after2018');
    const isPre2018Auto = (type === 'otomobil' && formData.registrationDate === 'before2018');
    const isElectricAuto = (type === 'elektrikli_otomobil');

    let minYear = 1977;
    let maxYear = 2026;

    if (isElectricAuto) minYear = 2019;
    else if (isPost2018Auto) minYear = 2018;
    else if (isPre2018Auto) maxYear = 2017;

    const opts = [{ value: '', label: 'Seçiniz' }];
    for (let yr = maxYear; yr >= minYear; yr--) {
        opts.push({ value: String(yr), label: String(yr) });
    }
    if (maxYear >= 2011 && minYear <= 2011) {
        opts.push({ value: '2011_down', label: '2011 ve Öncesi (16+ Yaş)' });
    }

    openCustomPicker('Model Yılı Seçin', opts, formData.vehicleModelYear, (val, lbl) => {
        formData.vehicleModelYear = val;
        // Logic for auto-selecting age based on year
        handleYearSelectLogic(val);
        // Refresh triggers
        const yearTrigger = document.getElementById('trigger-year');
        if (yearTrigger) yearTrigger.innerText = lbl;

        const ageTrigger = document.getElementById('trigger-age');
        if (ageTrigger) ageTrigger.innerText = formData.displayDetails.ageLabel || 'Seçiniz';

        // Refresh to update disabled states
        const dynamicInputs = document.getElementById('dynamicInputs');
        if (dynamicInputs) {
            dynamicInputs.innerHTML = getBodyInputsHTML();
            lucide.createIcons();
            // Matrah mantığını DOM güncellendikten SONRA çalıştır
            runMatrahUpdate();
        }
    });
}

function handleYearSelectLogic(val) {
    if (!val) {
        formData.vehicleAge = '';
        formData.displayDetails.ageLabel = 'Seçiniz';
        return;
    }

    let ageVal;
    if (val === '2011_down') {
        ageVal = 20; // 16+
    } else {
        ageVal = 2026 - parseInt(val) + 1;
    }

    let ageKey = '1-3';
    let label = '1 - 3 Yaş';

    const type = formData.vehicleType;
    const isCommercial = ['minibus', 'otobus', 'kamyonet', 'panelvan', 'elektrikli_minibus', 'elektrikli_otobus', 'elektrikli_kamyonet', 'elektrikli_panelvan'].includes(type) || type.includes('kamyonet');
    const isAir = (type === 'ucak' || type === 'helikopter');

    if (isAir) {
        if (ageVal <= 3) { ageKey = '1-3'; label = '1 - 3 Yaş'; }
        else if (ageVal <= 5) { ageKey = '4-5'; label = '4 - 5 Yaş'; }
        else if (ageVal <= 10) { ageKey = '6-10'; label = '6 - 10 Yaş'; }
        else { ageKey = '11+'; label = '11+ Yaş'; }
    } else if (isCommercial) {
        if (ageVal <= 6) { ageKey = '1-6'; label = '1 - 6 Yaş'; }
        else if (ageVal <= 15) { ageKey = '7-15'; label = '7 - 15 Yaş'; }
        else { ageKey = '16+'; label = '16+ Yaş'; }
    } else {
        if (ageVal <= 3) { ageKey = '1-3'; label = '1 - 3 Yaş'; }
        else if (ageVal <= 7) { ageKey = '4-6'; label = '4 - 6 Yaş'; }
        else if (ageVal <= 11) { ageKey = '7-11'; label = '7 - 11 Yaş'; }
        else if (ageVal <= 15) { ageKey = '12-15'; label = '12 - 15 Yaş'; }
        else { ageKey = '16+'; label = '16+ Yaş'; }
    }

    formData.vehicleAge = ageKey;
    formData.displayDetails.ageLabel = label;
    // Matrah güncellemesini burada çağırmaya gerek yok, picker içinde DOM güncellendikten sonra çağrılıyor.
}

function openCustomAgePicker() {
    // Profesyonel: Model yılı seçiliyse temizle ve devam et
    if (formData.vehicleModelYear) {
        formData.vehicleModelYear = '';
        formData.displayDetails.ageLabel = '';
    }

    const type = formData.vehicleType;
    const isElectric = type.startsWith('elektrikli');
    const isComm = ['minibus', 'otobus', 'kamyonet', 'panelvan', 'elektrikli_minibus', 'elektrikli_otobus', 'elektrikli_kamyonet', 'elektrikli_panelvan'].includes(type) || type.includes('kamyonet');
    const isAir = (type === 'ucak' || type === 'helikopter');
    const isPost2018Auto = (type === 'otomobil' && formData.registrationDate === 'after2018');
    const isPre2018Auto = (type === 'otomobil' && formData.registrationDate === 'before2018');

    const opts = [{ value: '', label: 'Seçiniz' }];

    if (isAir) {
        opts.push({ value: '1-3', label: '1 - 3 Yaş' }, { value: '4-5', label: '4 - 5 Yaş' }, { value: '6-10', label: '6 - 10 Yaş' }, { value: '11+', label: '11+ Yaş' });
    } else if (isComm) {
        opts.push({ value: '1-6', label: '1 - 6 Yaş' }, { value: '7-15', label: '7 - 15 Yaş' }, { value: '16+', label: '16+ Yaş' });
    } else if (type === 'motosiklet') {
        opts.push({ value: '1-3', label: '1 - 3 Yaş' }, { value: '4-6', label: '4 - 6 Yaş' }, { value: '7-11', label: '7 - 11 Yaş' }, { value: '12-15', label: '12 - 15 Yaş' }, { value: '16+', label: '16+ Yaş' });
    } else {
        if (isPost2018Auto) {
            opts.push({ value: '1-3', label: '1 - 3 Yaş' }, { value: '4-6', label: '4 - 6 Yaş' }, { value: '7-11', label: '7 - 11 Yaş' });
        } else if (isPre2018Auto) {
            opts.push({ value: '7-11', label: '7 - 11 Yaş' }, { value: '12-15', label: '12 - 15 Yaş' }, { value: '16+', label: '16+ Yaş' });
        } else {
            opts.push({ value: '1-3', label: '1 - 3 Yaş' }, { value: '4-6', label: '4 - 6 Yaş' }, { value: '7-11', label: '7 - 11 Yaş' }, { value: '12-15', label: '12 - 15 Yaş' }, { value: '16+', label: '16+ Yaş' });
        }
    }

    openCustomPicker('Araç Yaşı Seçin', opts, formData.vehicleAge, (val, lbl) => {
        formData.vehicleAge = val;
        formData.displayDetails.ageLabel = lbl;
        const trigger = document.getElementById('trigger-age');
        if (trigger) trigger.innerText = lbl;

        // Refresh to update disabled states
        const dynamicInputs = document.getElementById('dynamicInputs');
        if (dynamicInputs) {
            dynamicInputs.innerHTML = getBodyInputsHTML();
            lucide.createIcons();
            // Matrah mantığını DOM güncellendikten SONRA çalıştır
            runMatrahUpdate();
        }
    });
}


// --- VIRTUAL ROUTER ARCHITECTURE ---

// State
let currentView = 'home';
let formData = {
    calculationMode: 'MTV',
    registrationDate: 'after2018',
    registrationYear: 2026,
    vehicleType: '', // e.g. 'otomobil', 'elektrikli_otomobil'
    engineSize: '', // Boş başlasın - kullanıcı seçmeli
    motorPower: '', // Boş başlasın - kullanıcı seçmeli
    vehicleValue: 0,
    matrahTier: 0,
    vehicleWeight: '', // Boş başlasın - kullanıcı seçmeli
    vehicleAge: '', // Boş başlasın - kullanıcı seçmeli
    vehicleModelYear: '', // Capture specific year if chosen
    vehicleSeat: '', // Boş başlasın - kullanıcı seçmeli
    panelvanEngine: '', // Boş başlasın - kullanıcı seçmeli
    motoEngine: '', // Boş başlasın - kullanıcı seçmeli
    displayDetails: {} // To store labels for display
};

// --- PREMIUM & ADS LOGIC (Google Play Billing & AdMob) ---
let isPremium = localStorage.getItem('isPremium') === 'true';

// --- NATIVE BILLING CALLBACKS ---
window.onPurchaseSuccess = (result) => {
    isPremium = true;
    localStorage.setItem('isPremium', 'true');
    hideBanner();
    updateAdsVisibility();
    showModal("Tebrikler!", "Satın alma başarılı! Reklamlar kalıcı olarak kaldırıldı.", "info");
    if (currentView === 'home' || currentView === 'result') navigateTo('home');
};

window.onPurchaseError = (error) => {
    if (error && error.includes("Kullanıcı iptal")) return;
    showModal("Bilgi", error, "info");
};

async function initBilling() {
    // Native Android zaten başlatıyor
    if (typeof AndroidTheme !== 'undefined' && AndroidTheme.checkPremium) {
        AndroidTheme.checkPremium();
    }
}

async function removeAds() {
    playClickSound();

    if (typeof AndroidTheme !== 'undefined' && AndroidTheme.removeAds) {
        AndroidTheme.removeAds();
    } else {
        showModal("Hata", "Ödeme sistemi şu anda kullanılamıyor.", "warning");
    }
}

// --- NATIVE ADMOB (BRIDGE) ---
let onAdDismissedCallback = null;

// Native'den çağrılan callback
window.onAdDismissed = (result) => {
    if (onAdDismissedCallback) {
        onAdDismissedCallback();
        onAdDismissedCallback = null;
    }
};

async function initAdMob() {
    // Native Android onCreate içinde zaten başlatıyor.
}

async function showBanner() {
    // Native otomatik gösteriyor.
}

async function hideBanner() {
    // Native Interface ile kaldırabiliriz ama genelde premium olunca kalkar.
}

async function prepareInterstitial() {
    // Native otomatik yüklüyor.
}

// GÜVENLİ REKLAM TETİKLEME
async function showInterstitialAd() {
    // 1. Premium ise direkt geç
    if (localStorage.getItem('isPremium') === 'true') {
        return Promise.resolve();
    }

    return new Promise((resolve) => {
        // Güvenlik: 3 saniye içinde reklam açılmazsa/yanıt gelmezse otomatik geç
        const safetyTimer = setTimeout(() => {
            console.log("Reklam zaman aşımı - devam ediliyor.");
            resolve();
        }, 3000);

        // Java'dan gelecek yanıtı bekleyen callback
        window.onAdDismissed = (result) => {
            clearTimeout(safetyTimer); // Zamanlayıcıyı iptal et
            resolve();
        };

        // Java Köprüsünü Çağır
        if (typeof AndroidTheme !== 'undefined' && AndroidTheme.showInterstitial) {
            AndroidTheme.showInterstitial();
        } else {
            // Köprü yoksa (Tarayıcıdaysak) bekleme yapma
            clearTimeout(safetyTimer);
            resolve();
        }
    });
}

async function showBanner() {
    if (isPremium) return;

    try {
        const { AdMob } = window.Capacitor.Plugins;
        if (!AdMob) return;

        const options = {
            adId: BANNER_AD_ID,
            adSize: 'BANNER',
            position: 'BOTTOM_CENTER',
            margin: 0,
            isTesting: true
        };
        await AdMob.showBanner(options);
    } catch (e) {
        console.error('Banner show error:', e);
    }
}

async function hideBanner() {
    try {
        const { AdMob } = window.Capacitor.Plugins;
        if (AdMob) await AdMob.removeBanner();
    } catch (e) { }
}

async function prepareInterstitial() {
    if (isPremium) return;
    try {
        const { AdMob } = window.Capacitor.Plugins;
        if (!AdMob) return;

        await AdMob.prepareInterstitial({
            adId: INTERSTITIAL_AD_ID,
            isTesting: true
        });
    } catch (e) {
        console.error('Prepare Interstitial Error:', e);
    }
}

async function showInterstitialAd() {
    if (isPremium) return Promise.resolve();

    return new Promise((resolve) => {
        // Set callback for when ad is dismissed
        onInterstitialDismissedCallback = resolve;

        // Attempt to show
        const { AdMob } = window.Capacitor.Plugins;
        if (!AdMob) {
            resolve();
            return;
        }

        AdMob.showInterstitial().catch((e) => {
            console.error('Show Interstitial Error/Not Ready:', e);
            // If it fails (e.g. not loaded), resolve immediately
            resolve();
        });
    });
}

function clearAppCache() {
    localStorage.clear();
    if ('caches' in window) {
        caches.keys().then(names => {
            for (let name of names) caches.delete(name);
        });
    }
    // Delay reload to allow sound to play
    setTimeout(() => location.reload(true), 100);
}

function resetPremium() {
    localStorage.removeItem('isPremium');
    location.reload();
}

function reloadPage() {
    // Delay reload to allow sound to play
    setTimeout(() => location.reload(), 100);
}

